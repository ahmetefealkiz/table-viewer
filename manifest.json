{
  "manifest_version": 3,
  "name": "Banka İşlem Test Botu",
  "version": "1.0.0",
  "description": "Banka ödeme geçmişi verilerini özel seçicilerle okuma ve test etme eklentisi",
  "key": "",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "alarms",
    "power"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "oauth2": {
    "client_id": "240954843860-kns2986tkseu8q4e0d1vshnrsn0f2850.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/drive.readonly",
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Banka İşlem Test Botu"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
